# Copy this file to .dev.vars (for wrangler local dev) or set as Cloudflare Worker secret.
# Never commit .dev.vars or any file containing a real API key.

# Anthropic API key — used by server/proxy.js only; never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: override the proxy URL the app uses (defaults to /api/claude).
# Set this if deploying the Worker to a different domain than the app.
# VITE_CLAUDE_PROXY_URL=https://sorrel-proxy.your-account.workers.dev
